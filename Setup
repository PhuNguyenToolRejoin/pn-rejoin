#!/bin/bash
# PN TOOL REJOIN - Setup Script (Fix for Python 3.11)

# 1. Cấp quyền & Cài đặt hệ thống
termux-setup-storage
sleep 2

echo "Dang cap nhat he thong..."
pkg update -y && pkg upgrade -y

# Cài đặt tur-repo để có Python 3.11
echo "Dang thiet lap kho luu tru phu (TUR)..."
pkg install tur-repo -y
pkg update -y

# Cài đặt Python 3.11 và các công cụ cần thiết
echo "Dang cai dat Python 3.11..."
pkg install python3.11 curl python-is-python3.11 -y

# Cài đặt thư viện requests cho đúng bản 3.11
echo "Dang cai dat thu vien..."
python3.11 -m pip install requests

# 2. Tải Tool
FILE_PATH="/sdcard/Download/pn.py"
DOWNLOAD_URL="https://raw.githubusercontent.com/PhuNguyenToolRejoin/pn-rejoin/main/main.py"

echo "Dang tai tool..."
curl -L -o $FILE_PATH $DOWNLOAD_URL

if [ -f "$FILE_PATH" ]; then
    if grep -q "404: Not Found" "$FILE_PATH"; then
        echo "Lỗi: Link GitHub vẫn sai (404)!"
        rm $FILE_PATH
    else
        echo "------------------------------------------"
        echo "    DA CAI DAT XONG TOOL REJOIN BY PN     "
        echo "    Phien ban Python: 3.11 (Fixed)        "
        echo "    Lenh chay: python pn.py               "
        echo "------------------------------------------"
    fi
else
    echo "Loi: Khong the tai file!"
fi
