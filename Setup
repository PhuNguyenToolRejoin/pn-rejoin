#!/bin/bash
# PN TOOL REJOIN - Setup Script (Auto Fix Python 3.11)

# 1. Cấp quyền & Cập nhật hệ thống
termux-setup-storage
sleep 2

echo "Dang cap nhat he thong..."
pkg update -y && pkg upgrade -y

# 2. Thêm kho lưu trữ TUR và cài Python 3.11
echo "Dang thiet lap Python 3.11 (Vui long cho...)"
pkg install tur-repo -y
pkg update -y
pkg install python3.11 python-is-python3.11 curl -y

# 3. Cài đặt thư viện cho bản 3.11
echo "Dang cai dat thu vien Requests..."
python3.11 -m pip install requests

# 4. Tải Tool
FILE_PATH="/sdcard/Download/pn.py"
DOWNLOAD_URL="https://raw.githubusercontent.com/PhuNguyenToolRejoin/pn-rejoin/main/main.py"

echo "Dang tai tool..."
curl -L -o $FILE_PATH $DOWNLOAD_URL

if [ -f "$FILE_PATH" ]; then
    echo "------------------------------------------"
    echo "    DA CAI DAT XONG TOOL REJOIN BY PN     "
    echo "    He thong da tu dong ha cap xuong 3.11 "
    echo "    Lenh chay: python pn.py               "
    echo "------------------------------------------"
else
    echo "Loi: Khong the tai file!"
fi
