#!/bin/bash
# PN TOOL REJOIN - Setup Script
# Tải main.py từ GitHub và lưu thành pn.py trên máy khách

# 1. Cấp quyền & Cài đặt
termux-setup-storage
sleep 2
pkg update -y && pkg upgrade -y
pkg install python tsu curl -y
pip install requests

# 2. Tải Tool (Dùng link RAW và file main.py)
# Lưu ý: Tôi tải file main.py nhưng lưu tên là pn.py để bạn chạy lệnh cũ vẫn được
FILE_PATH="/sdcard/Download/pn.py"
DOWNLOAD_URL="https://raw.githubusercontent.com/PhuNguyenToolRejoin/pn-rejoin/main/main.py"

echo "Dang tai tool..."
curl -L -o $FILE_PATH $DOWNLOAD_URL

if [ -f "$FILE_PATH" ]; then
    # Kiểm tra xem có bị tải nhầm file 404 không
    if grep -q "404: Not Found" "$FILE_PATH"; then
        echo "Lỗi: Link GitHub vẫn sai (404). Hãy kiểm tra lại tên file trên GitHub là main.py hay pn.py!"
        rm $FILE_PATH
    else
        echo "------------------------------------------"
        echo "   DA CAI DAT XONG TOOL REJOIN BY PN      "
        echo "   Lenh chay: python /sdcard/Download/pn.py"
        echo "------------------------------------------"
    fi
else
    echo "Loi: Khong the tai file!"
fi
